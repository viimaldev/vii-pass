# Production build config for the vii-pass SPA.
#
# Empty API base URL = call the API on the SAME origin as the app (relative
# `/api/...`). In the free single-origin deploy the React build is served by the
# same Cloudflare Worker that hosts the API, so no absolute URL is needed and the
# SameSite=Lax session cookie stays first-party.
VITE_API_BASE_URL=
