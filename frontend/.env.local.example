# vii-pass web app — local development environment (Vite).
# Copy this file to `frontend/.env.local` and adjust as needed.
# `.env.local` is git-ignored and MUST NOT be committed (FR-008, SC-007).

# Base URL of the vii-pass API (the Cloudflare Worker). In local dev this is the
# `wrangler dev` address; in production set it to the deployed Worker URL/domain.
VITE_API_BASE_URL="http://localhost:8787"
